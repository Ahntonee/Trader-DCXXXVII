# ─── Twelve Data (forex + crypto data) ───────────────────────
# Sign up free at https://twelvedata.com → Dashboard → API Keys
TWELVE_DATA_KEY=your_twelve_data_key_here

# ─── Telegram Bot ─────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → follow steps → copy token here
# 2. Start your bot, then visit: https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id after sending the bot a message
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
